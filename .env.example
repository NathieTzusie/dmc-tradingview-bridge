# ─────────────────────────────────────────────────────────────
# DMC TradingView Bridge — 环境变量配置
# 复制此文件为 .env 并填入你的 API key
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# === 必填：鉴权 Token（任意长随机字符串）===
TV_BRIDGE_AUTH_TOKEN=change-me-to-a-random-token

# === 交易所 API Key（至少配一个）===

# --- Binance Testnet（推荐新手使用） ---
TV_BRIDGE_BINANCE_API_KEY=
TV_BRIDGE_BINANCE_API_SECRET=
TV_BRIDGE_BINANCE_TESTNET=true

# --- Binance 主网 ---
# TV_BRIDGE_BINANCE_API_KEY=
# TV_BRIDGE_BINANCE_API_SECRET=
# TV_BRIDGE_BINANCE_TESTNET=false

# --- Bybit Testnet ---
# TV_BRIDGE_BYBIT_API_KEY=
# TV_BRIDGE_BYBIT_API_SECRET=
# TV_BRIDGE_BYBIT_TESTNET=true

# --- OKX Testnet ---
# TV_BRIDGE_OKX_API_KEY=
# TV_BRIDGE_OKX_API_SECRET=
# TV_BRIDGE_OKX_API_PASSPHRASE=
# TV_BRIDGE_OKX_TESTNET=true

# === 安全 ===
TV_BRIDGE_EMERGENCY_STOP=false
